# Template para segredos adicionais (JWT, chaves de API futuras).
# Copie para application-secrets.yml e preencha os valores reais.
# application-secrets.yml é gitignored — nunca commitar com segredos reais.

# Exemplo de uso:
# spring:
#   config:
#     import: application-secrets.yml

# Gere o secret com: openssl rand -base64 32
jwt:
  secret: <seu-jwt-secret-base64-aqui>
